@model Correspondence
@{
    ViewData["Title"] = "Delete correspondence";
}

<div class="page-header">
    <h1>Delete correspondence</h1>
</div>

<div class="panel">
    <p>Delete correspondence <strong>@(Model.Subject ?? "(No subject)")</strong>?</p>
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="form-actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a class="btn btn-outline-secondary" asp-action="Details" asp-route-id="@Model.Id">Cancel</a>
        </div>
    </form>
</div>
