@model FollowUp
@{
    ViewData["Title"] = Model.Id == 0 ? "New follow-up" : "Edit follow-up";
}

<div class="page-header">
    <h1>@ViewData["Title"]</h1>
</div>

<div class="panel">
    <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-12">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" required />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="DueOn" class="form-label">Due on</label>
                <input asp-for="DueOn" class="form-control" type="datetime-local" value="@Model.DueOn.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
            </div>
            <div class="col-md-6 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="IsDone" class="form-check-input" />
                    <label asp-for="IsDone" class="form-check-label">Done</label>
                </div>
            </div>
            <div class="col-md-6">
                <label asp-for="CompanyId" class="form-label">Company</label>
                <select asp-for="CompanyId" class="form-select" asp-items="ViewBag.Companies">
                    <option value="">(None)</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="PersonId" class="form-label">Person</label>
                <select asp-for="PersonId" class="form-select" asp-items="ViewBag.People">
                    <option value="">(None)</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" asp-action="Index">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
