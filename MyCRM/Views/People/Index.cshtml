@model IEnumerable<Person>
@{
    ViewData["Title"] = "People";
    var search = ViewBag.Search as string;
}

<div class="page-header">
    <h1>People</h1>
    <a class="btn btn-primary btn-sm" asp-action="Create">New person</a>
</div>

<div class="panel">
    <form method="get" class="row g-2 align-items-end mb-3">
        <div class="col-md-6">
            <label class="form-label" for="q">Search</label>
            <input class="form-control" id="q" name="q" value="@search" placeholder="First or last name…" />
        </div>
        <div class="col-md-3 actions">
            <button type="submit" class="btn btn-outline-secondary">Search</button>
            <a class="btn btn-link" asp-action="Index">Clear</a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <p class="empty-state mb-0">No people found.</p>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><a asp-action="Details" asp-route-id="@item.Id">@item.FirstName @item.LastName</a></td>
                        <td>@item.CreatedAt.ToLocalTime().ToString("d")</td>
                        <td class="text-end actions">
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>
