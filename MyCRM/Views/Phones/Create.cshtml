@model Phone
@{
    ViewData["Title"] = Model.Id == 0 ? "Add phone" : "Edit phone";
}

<div class="page-header">
    <h1>@ViewData["Title"]</h1>
</div>

<div class="panel">
    <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-8">
                <label asp-for="PhoneNumber" class="form-label">Phone</label>
                <input asp-for="PhoneNumber" class="form-control" required />
                <span asp-validation-for="PhoneNumber" class="text-danger"></span>
            </div>
            <div class="col-md-4 d-flex align-items-end">
                <div class="form-check mb-2">
                    <input asp-for="IsPrimary" class="form-check-input" />
                    <label asp-for="IsPrimary" class="form-check-label">Primary</label>
                </div>
            </div>
            <div class="col-md-6">
                <label asp-for="CompanyId" class="form-label">Company</label>
                <select asp-for="CompanyId" class="form-select" asp-items="ViewBag.Companies">
                    <option value="">(None)</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="PersonId" class="form-label">Person</label>
                <select asp-for="PersonId" class="form-select" asp-items="ViewBag.People">
                    <option value="">(None)</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="javascript:history.back()">Cancel</a>
        </div>
    </form>
</div>
