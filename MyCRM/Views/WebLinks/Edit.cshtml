@model WebLink
@{
    ViewData["Title"] = "Edit link";
}

<div class="page-header">
    <h1>Edit link</h1>
</div>

<div class="panel">
    <form asp-action="Edit" method="post">
        <div asp-validation-summary="All" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Description" class="form-label"></label>
                <input asp-for="Description" class="form-control" required />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Link" class="form-label">URL</label>
                <input asp-for="Link" class="form-control" type="url" placeholder="https://" required />
                <span asp-validation-for="Link" class="text-danger"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CompanyId" class="form-label">Company</label>
                <select asp-for="CompanyId" class="form-select" asp-items="ViewBag.Companies">
                    <option value="">(None)</option>
                </select>
            </div>
            <div class="col-md-6">
                <label asp-for="PersonId" class="form-label">Person</label>
                <select asp-for="PersonId" class="form-select" asp-items="ViewBag.People">
                    <option value="">(None)</option>
                </select>
            </div>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save</button>
            <a class="btn btn-outline-secondary" href="javascript:history.back()">Cancel</a>
        </div>
    </form>
</div>
